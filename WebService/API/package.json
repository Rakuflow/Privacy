{
  "name": "raku-shield",
  "version": "1.0.0",
  "description": "RakuShield is a privacy-focused relayer service for Starknet, enabling users to interact with the Starknet Shielded Pool while maintaining their privacy. It provides secure and efficient transaction relaying, allowing users to shield and unshield their assets on Starknet without exposing their identities.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "generate-wallet": "node scripts/generate-wallet.mjs",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "starknet",
    "zk",
    "relayer",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "mongoose": "^8.0.0",
    "nodemon": "^3.1.14",
    "pino": "^9.12.0",
    "starknet": "^8.1.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
