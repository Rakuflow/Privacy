## Server
PORT=3001
LOG_LEVEL=info

## Starknet relayer account (required)
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY
RELAYER_ADDRESS=0xYOUR_RELAYER_ACCOUNT_ADDRESS
RELAYER_CAIRO_VERSION=1
RELAYER_TX_MAX_FEE_WEI=100000000000000000

## Chain contracts (required for runtime)
SHIELDED_POOL_CONTRACT=0xYOUR_SHIELDED_POOL_CONTRACT

## RPC (recommended to set explicitly)
RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_KEY

## MongoDB (required)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=test_net
